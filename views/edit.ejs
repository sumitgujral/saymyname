<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Document</title>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 p-10 text-white">
        <div class=" w-full flex justify-end">
            <a class="bg-red-600 p-1 rounded-md inline-block" href="/logout">Logout</a>
        </div>
        <h4 class="mb-5 text-2xl">Update post</h4>
        <form method="post" action="/update/<%= post._id %>">
            <textarea class="resize-none p-2 mt-2 w-1/3 rounded-md border-zinc-700 border-2 outline-none" name="content" placeholder="Edit your post.."><%= post.content%></textarea>
            <input class="bg-yellow-400 text-black block mt-2 p-2 w-1/10 rounded-md" type="submit" value="Update Post">
        </form>

    
    </div>
</body>
</html>